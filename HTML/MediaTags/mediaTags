<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Tags</title>
</head>;
<body>
    <!--media Tag 1-->
       <!--absolute path (src)-->
    <img src="https://cdn.pixabay.com/photo/2025/09/22/17/45/vietnam-9849101_1280.jpg" alt="image not available" height="200px" width="200px">

    <br>
    <!--media Tag 2-->
       <!--absolute path (src)-->
       <!--as long as no controls can't play video-->
       <video src="https://cdn.pixabay.com/video/2025/05/06/277042_large.mp4"
       alt="video not available" height="200px" width="250px" poster="https://cdn.pixabay.com/photo/2025/09/22/17/45/vietnam-9849101_1280.jpg" controls loop autoplay>
       </video>

         <!--source for low end browser/device compatibility-->
      <video src="https://cdn.pixabay.com/video/2025/05/06/277042_large.mp4"
       alt="video not available" height="200px" width="250px" poster="https://cdn.pixabay.com/photo/2025/09/22/17/45/vietnam-9849101_1280.jpg" controls loop autoplay>
       <source src="https://cdn.pixabay.com/video/2025/05/06/277042_large.mp4">
    </video>

    <!--media Tag 3-->
       <!--as long as no controls can't play audio-->
    <audio src="C:\Users\DELL\Desktop\Frontend_capg\media\alexgrohl-energetic-action-sport-500409.mp3"
     controls autoplay loop>
     <source src="C:\Users\DELL\Desktop\Frontend_capg\media\alexgrohl-energetic-action-sport-500409.mp3">
    </audio>
</body>
</html>